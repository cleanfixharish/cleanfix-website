{
    "title": "leads",
    "type": "object",
    "properties": {
        "id": {
            "type": "integer"
        },
        "customer_name": {
            "type": "string",
            "maxLength": 200
        },
        "phone": {
            "type": "string",
            "maxLength": 50
        },
        "whatsapp": {
            "type": "string",
            "maxLength": 50
        },
        "email": {
            "type": "string",
            "maxLength": 200
        },
        "area": {
            "type": "string",
            "maxLength": 100
        },
        "service_requested": {
            "type": "string",
            "maxLength": 200
        },
        "description": {
            "type": "string"
        },
        "source": {
            "type": "string",
            "maxLength": 100,
            "description": "website, whatsapp, facebook, instagram, referral, phone"
        },
        "status": {
            "type": "string",
            "maxLength": 50,
            "default": "new",
            "description": "new, contacted, quoted, booked, completed, lost"
        },
        "assignment": {
            "type": "string",
            "maxLength": 50,
            "description": "internal, partner"
        },
        "assigned_partner_id": {
            "type": "integer"
        },
        "quote_status": {
            "type": "string",
            "maxLength": 50,
            "description": "pending, sent, accepted, rejected"
        },
        "booking_status": {
            "type": "string",
            "maxLength": 50,
            "description": "pending, confirmed, in_progress, completed, cancelled"
        },
        "follow_up_status": {
            "type": "string",
            "maxLength": 50,
            "description": "none, scheduled, overdue, done"
        },
        "follow_up_date": {
            "type": "string",
            "format": "date"
        },
        "notes": {
            "type": "string"
        },
        "outcome": {
            "type": "string",
            "maxLength": 100
        },
        "priority": {
            "type": "string",
            "maxLength": 20,
            "default": "normal"
        }
    },
    "required": [
        "customer_name",
        "phone"
    ]
}